---
import type { HTMLAttributes } from "astro/types";
interface Props extends HTMLAttributes<"a"> {}
const props = Astro.props;
---

<a {...props} class="font-semibold inline no-underline bg-gradient-to-t from-mizugaki/50 to-mizugaki/50 dark:from-mizugaki/70 dark:to-mizugaki/70 bg-no-repeat bg-left-bottom bg-[length:100%_10px] hover:bg-[length:100%_24px] transition-all duration-300 pb-[1px]"><slot/></a>