---
import { getCollection, render } from "astro:content";
import HeadingWithUnderline from "@components/HeadingWithUnderline.astro";
import mdComponent from "@components/md/components";

const news = await getCollection("news");

const newsItems = news.sort((a, b) => {
    const aTime = new Date(`${a.data.date}T00:00:00`).getTime();
    const bTime = new Date(`${b.data.date}T00:00:00`).getTime();
    return bTime - aTime;
});

const dateFormatter = new Intl.DateTimeFormat("en", {
    month: "short",
    year: "numeric",
});
---

<section class="mb-24">
    <HeadingWithUnderline text="News" />

    <ul>
        {
            newsItems.map(async (item) => {
                const date = new Date(`${item.data.date}T00:00:00`);
                const formattedDate = dateFormatter.format(date);
                const { Content } = await render(item);

                return (
                    <li class="mb-3">
                        <article class="flex flex-col sm:flex-row sm:items-start gap-4">
                            <div class="min-w-[6.5rem] shrink-0 flex justify-start sm:justify-center">
                                <span class="sm:w-full bg-mizugaki/10 text-mizugaki dark:text-mizugaki/90 border border-mizugaki/20 px-3 py-1 rounded-full text-xs font-bold tracking-wider shadow-sm text-center">
                                    {formattedDate}
                                </span>
                            </div>
                            <div class="min-w-0 [&>*]:mt-0">
                                <Content components={mdComponent} />
                            </div>
                        </article>
                    </li>
                );
            })
        }
    </ul>
</section>
