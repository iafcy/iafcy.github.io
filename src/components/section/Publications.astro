---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import HeadingWithUnderline from "@components/HeadingWithUnderline.astro";
import YearHeading from "@components/YearHeading.astro";

import { ScrollText, Code, Link, FilePen } from "lucide-react";
import { Icon } from 'astro-icon/components'

const NAME = "Yiu-Fai Cheung";

type PublicationData = CollectionEntry<"publications">["data"];
type PublicationsByYear = Record<number, PublicationData[]>;

const publications = await getCollection("publications");
const publicationsByYear = publications.reduce<PublicationsByYear>(
    (groups, { data }) => {
        const year = data.year;

        if (!groups[year]) groups[year] = [];

        groups[year].push(data);
        return groups;
    },
    {}
);

const years = Object.keys(publicationsByYear)
    .map(Number)
    .sort((a, b) => b - a);
---

<section class="mb-24">
    <HeadingWithUnderline text="Publications" />

    {
        years.map((year) => (
            <div class="mb-12">
                <YearHeading year={year} />

                <ul>
                    {publicationsByYear[year].map((data) => {
                        const authors = data.authors
                            .split(",")
                            .map((author) => {
                                const trimmedAuthor = author.trim().replace(/\s+([*†]+)$/u, "$1");
                                const markerMatch = trimmedAuthor.match(/^(.*?)([*†]+)$/u);
                                const authorName = markerMatch ? markerMatch[1].trimEnd() : trimmedAuthor;
                                const markers = markerMatch?.[2] ? `<sup>${markerMatch[2]}</sup>` : "";
                                return authorName === NAME
                                    ? `<strong class=\"font-bold\">${`${authorName}${markers}`}</strong>`
                                    : `${authorName}${markers}`;
                            })
                            .join(", ");

                        return (
                            <li id={data.id} class="sm:grid sm:grid-cols-3 gap-6 mb-8 items-center scroll-mt-32">
                                <div class="col-span-1 hidden sm:block rounded-md overflow-hidden">
                                    <Image
                                        src={data.image}
                                        alt="pub"
                                        class="transition duration-300 ease-in-out object-contain hover:scale-105 hover:opacity-85"
                                    />
                                </div>
                                <div class="sm:col-span-2 flex flex-col gap-2 text-base">
                                    <h3 class="text-lg font-bold">
                                        {data.title}
                                    </h3>
                                    <p set:html={authors} />
                                    <p class="italic underline">{data.venue}</p>
                                    {data.award && (
                                        <p class="font-bold">{data.award}</p>
                                    )}

                                    <div class="flex gap-8 items-center mt-2">
                                        {data.links?.paper && (
                                            <a
                                                href={data.links.paper}
                                                class="flex items-center gap-2"
                                            >
                                                <ScrollText className="h-5 w-5" />
                                                Paper
                                            </a>
                                        )}

                                        {data.links?.arxiv && (
                                            <a
                                                href={data.links.arxiv}
                                                class="flex items-center gap-2"
                                            >
                                                <Icon name="arxiv" class="h-5 w-5 grayscale-[80%]" />
                                                arXiv
                                            </a>
                                        )}

                                        {data.links?.preprint && (
                                            <a
                                                href={data.links.preprint}
                                                class="flex items-center gap-2"
                                            >
                                                <FilePen className="h-5 w-5" />
                                                Preprint
                                            </a>
                                        )}

                                        {data.links?.code && (
                                            <a
                                                href={data.links.code}
                                                class="flex items-center gap-2"
                                            >
                                                <Code className="h-5 w-5" />
                                                Code
                                            </a>
                                        )}

                                        {data.links?.website && (
                                            <a
                                                href={data.links.website}
                                                class="flex items-center gap-2"
                                            >
                                                <Link className="h-5 w-5" />
                                                Website
                                            </a>
                                        )}
                                    </div>
                                </div>
                            </li>
                        );
                    })}
                </ul>
            </div>
        ))
    }
</section>
